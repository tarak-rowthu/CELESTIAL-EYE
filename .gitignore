# =============================================================================
#  Project Zenith: The Celestial Eye — .gitignore
#  Full-stack: Next.js 15 (frontend) + Express + Prisma + MySQL (backend)
# =============================================================================


# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.pnp
.pnp.js


# ─── Environment Variables ───────────────────────────────────────────────────
# Never commit secrets. Provide a .env.example instead.
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local


# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/
frontend/.next/
frontend/out/


# ─── Build Output ────────────────────────────────────────────────────────────
dist/
build/
backend/dist/
frontend/build/


# ─── Prisma ──────────────────────────────────────────────────────────────────
# SQLite dev database (legacy — project now uses MySQL)
backend/prisma/dev.db
backend/prisma/dev.db-journal
# Do NOT ignore: backend/prisma/schema.prisma
# Do NOT ignore: backend/prisma/migrations/


# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*


# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts


# ─── Test Coverage ───────────────────────────────────────────────────────────
coverage/
*.lcov
.nyc_output/


# ─── Package Manager Locks (keep only the one you use) ───────────────────────
# Uncomment to ignore other lockfiles if your team uses only npm:
# yarn.lock
# pnpm-lock.yaml


# ─── IDE & Editor ────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ─── OS-Generated Files ──────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel


# ─── Miscellaneous ───────────────────────────────────────────────────────────
*.pem
.cache/
.parcel-cache/
*.tgz
